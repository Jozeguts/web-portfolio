rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.admin == true;
    }
    
    function validateContactForm() {
      return request.resource.data.keys().hasAll([
        'name', 'email', 'subject', 'message'
      ]) && request.resource.data.name is string &&
          request.resource.data.email is string &&
          request.resource.data.subject is string &&
          request.resource.data.message is string;
    }
    
    // Services: public read if active, admin can read/write all
    match /services/{document=**} {
      allow read: if resource.data.is_active == true;
      allow read, write: if isAdmin();
    }
    
    // Skills: public read if active, admin can read/write all
    match /skills/{document=**} {
      allow read: if resource.data.is_active == true;
      allow read, write: if isAdmin();
    }
    
    // Projects: public read if active, admin can read/write all
    match /projects/{document=**} {
      allow read: if resource.data.is_active == true;
      allow read, write: if isAdmin();
    }
    
    // Testimonials: public read if active, admin can read/write all
    match /testimonials/{document=**} {
      allow read: if resource.data.is_active == true;
      allow read, write: if isAdmin();
    }
    
    // Contact requests: admin can read, anyone can create
    match /contact_requests/{document=**} {
      allow read: if isAdmin();
      allow create: if validateContactForm();
    }
  }
}
